# =============================================================================
# ResuMesh — Root Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Application ---
APP_ENV=development
APP_NAME=ResuMesh
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,chrome-extension://*

# --- Database ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=resumesh
POSTGRES_USER=resumesh_user
POSTGRES_PASSWORD=resumesh_password_change_me
DATABASE_URL=postgresql+asyncpg://resumesh_user:resumesh_password_change_me@postgres:5432/resumesh

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT ---
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- ChromaDB ---
CHROMA_HOST=chromadb
CHROMA_PORT=8001
CHROMA_COLLECTION_RESUMES=resumesh_resumes
CHROMA_COLLECTION_JOBS=resumesh_jobs

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=resumesh-matching
MLFLOW_ARTIFACT_ROOT=./mlruns

# --- Airflow ---
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://resumesh_user:resumesh_password_change_me@postgres:5432/airflow
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-generate-with-cryptography
AIRFLOW__WEBSERVER__SECRET_KEY=your-webserver-secret-key
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@resumesh.com

# --- LLM Provider (Free Options) ---
# Option 1: Ollama (Self-hosted, Free)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# Option 2: Groq API (Free tier available)
GROQ_API_KEY=your-groq-api-key

# Option 3: Google Gemini (Free tier available)
GOOGLE_API_KEY=your-google-api-key

# Which LLM provider to use: ollama | groq | gemini
LLM_PROVIDER=ollama

# --- Sentence Transformers ---
SENTENCE_TRANSFORMER_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- Prometheus ---
PROMETHEUS_PORT=9090

# --- Grafana ---
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- File Storage ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,docx

# --- DVC ---
DVC_REMOTE=./data/remote
