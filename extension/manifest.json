{
  "manifest_version": 3,
  "name": "ResuMesh — AI Job Copilot",
  "version": "1.0.0",
  "description": "AI-powered job application assistant. Auto-analyzes jobs on LinkedIn, Wellfound, Internshala, and Naukri.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "ResuMesh"
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://linkedin.com/jobs/*"
      ],
      "js": ["src/content/linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://wellfound.com/jobs/*",
        "https://angel.co/jobs/*"
      ],
      "js": ["src/content/wellfound.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://internshala.com/internship/*",
        "https://internshala.com/jobs/*"
      ],
      "js": ["src/content/internshala.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.naukri.com/*",
        "https://naukri.com/*"
      ],
      "js": ["src/content/naukri.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://wellfound.com/*",
    "https://angel.co/*",
    "https://internshala.com/*",
    "https://www.naukri.com/*",
    "http://localhost:8000/*",
    "https://api.resumesh.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "src/sidebar/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
